@model WindowConfigurator.Web.Models.OrderViewModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>OrderViewModel</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Id" class="control-label"></label>
                <input asp-for="Id" class="form-control" />
                <span asp-validation-for="Id" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="FirstName" class="control-label"></label>
                <input asp-for="FirstName" class="form-control" />
                <span asp-validation-for="FirstName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="LastName" class="control-label"></label>
                <input asp-for="LastName" class="form-control" />
                <span asp-validation-for="LastName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Address" class="control-label"></label>
                <input asp-for="Address" class="form-control" />
                <span asp-validation-for="Address" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="SalesforceUserId" class="control-label"></label>
                <input asp-for="SalesforceUserId" class="form-control" />
                <span asp-validation-for="SalesforceUserId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="SalesForceOpportunityId" class="control-label"></label>
                <input asp-for="SalesForceOpportunityId" class="form-control" />
                <span asp-validation-for="SalesForceOpportunityId" class="text-danger"></span>
            </div>
            <h5>Items</h5>
            @foreach (var orderItem in Model.OrderItems)
            {
                <div class="form-group">
                    <a asp-controller="OrderItem" asp-action="Index" asp-route-id="@orderItem.Id">@orderItem.Id</a>
                    <p>@orderItem.Id</p>
                </div>
            }
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{
    await Html.RenderPartialAsync("_ValidationScriptsPartial");
}
}
