@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    Layout = null;
}
@model OrderItemViewModel

<!DOCTYPE html>

<html>
<head>
    <title>Order Item</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    @*    @Styles.Render("~/Content/Base")
        @Styles.Render("~/Content/StoreFront/Configurator/css")
    *@

    <link rel="stylesheet" href="~/css/bootstrap.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/configurator.css" asp-append-version="true" />

    <script src="~/js/knockout-3.4.1.debug.js" asp-append-version="true"></script>
    <script src="~/js/knockout.mapping-latest.debug.js" asp-append-version="true"></script>
    <script src="~/js/windowStore/fraction.js" asp-append-version="true"></script>
    <script src="~/js/windowStore/windowStore.measurement.js" asp-append-version="true"></script>
    <script src="~/js/windowStore/windowStore.order.item.preview.viewModel.js" asp-append-version="true"></script>
    <script src="~/js/windowStore/windowStore.order.item.validator.js" asp-append-version="true"></script>
    <script src="~/js/windowStore/windowStore.order.item.viewmodel.js" asp-append-version="true"></script>
    <script src="~/js/windowStore/windowStore.preview.sectionOptions.js" asp-append-version="true"></script>
    <script src="~/js/windowStore/pricing.js" asp-append-version="true"></script>

    @*@Scripts.Render("~/bundles/windowStore")*@

</head>

<body>

    <section id="popups">

        @*General Modal*@

        <div class="modal fade" id="general-modal" tabindex="-1" role="dialog">
            <div class="modal-dialog" role="document">
                <div class="align-content">
                    <div class="modal-body">
                        <div class="panel panel-default">
                            <div class="panel-heading">
                                General
                                <button type="button" class="close" data-dismiss="modal">
                                    <span>&times;</span>
                                </button>
                            </div>
                            <div class="panel-body">
                                <div class="row">
                                    <div class="col-xs-3 control-label">
                                        <p>Location</p>
                                    </div>
                                    <div class="col-xs-9">
                                        <input type="text" class="form-control" data-bind="value: location">
                                    </div>
                                </div>
                                <div class="row section-count">
                                    <div class="col-xs-3 control-label">
                                        <p>Sections</p>
                                    </div>
                                    <div class="col-xs-9">
                                        <button class="col-xs-4 btn btn-default" data-bind="click: onOneSectionButtonClick">
                                            <p>1</p>
                                        </button>
                                        <button class="col-xs-4 btn btn-default" data-bind="click: onTwoSectionButtonClick">
                                            <p>2</p>
                                        </button>
                                        <button class="col-xs-4 btn btn-default" data-bind="click: onThreeSectionButtonClick">
                                            <p>3</p>
                                        </button>
                                    </div>
                                </div>
                            </div>
                            <div class="panel-footer">
                                <button class="btn btn-default" data-dismiss="modal">OK</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Dimensions Modal -->

        <div class="modal fade" id="dimensions-modal" tabindex="-1" role="dialog">
            <div class="modal-dialog" role="document">
                <div class="align-content">
                    <div class="modal-body">
                        <div class="panel panel-default">
                            <div class="panel-heading">
                                Dimensions
                                <button type="button" class="close" data-dismiss="modal">
                                    <span>&times;</span>
                                </button>
                            </div>
                            <div class="panel-body">
                                <div class="row">
                                    <div class="col-xs-6">
                                        <p>Sizing Type</p>
                                    </div>
                                    <div class="col-xs-6">
                                        <div class="dropdown">
                                            <button class="btn btn-default dropdown-toggle" type="button" id="dropdownMenu1" data-toggle="dropdown" aria-haspopup="true" aria-expanded="true" data-bind="text: sizingType"><span class="caret"></span>
                                            </button>
                                            <ul class="dropdown-menu" aria-labelledby="dropdownMenu1">
                                                <li><a href="#" data-bind="click: onSizingTypeChangedBrickmould">Brickmould</a></li>
                                                <li><a href="#" data-bind="click: onSizingTypeChangedFrame">Frame</a></li>
                                            </ul>
                                        </div>
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-xs-6 control-label">
                                        <p>Width</p>
                                    </div>
                                    <div class="col-xs-6">
                                        <input type="text" class="form-control" data-bind="value: widthDescription" />
                                    </div>
                                </div>
                                <div class="row">
                                    <div class="col-xs-6 control-label">
                                        <p>Height</p>
                                    </div>
                                    <div class="col-xs-6">
                                        <input type="text" class="form-control" data-bind="value: heightDescription" />
                                    </div>
                                </div>
                            </div>
                            <div class="panel-footer">
                                <button class="btn btn-default" data-dismiss="modal">OK</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @*Fit/Finish Modal*@

        <div class="modal fade" id="fit-finish-modal" tabindex="-1" role="dialog">
            <div class="modal-dialog" role="document">
                <div class="align-content">
                    <div class="modal-body">
                        <div class="panel panel-default">
                            <div class="panel-heading">
                                Fit/Finish
                                <button type="button" class="close" data-dismiss="modal">
                                    <span>&times;</span>
                                </button>
                            </div>
                            <div class="panel-body">
                                <div class="row">
                                    <div class="col-xs-12 btn-group-vertical">
                                        <div class="row">
                                            <div class="col-xs-6">
                                                <p>Subsil</p>
                                            </div>
                                            <div class="col-xs-6">
                                                <input type="checkbox" id="keepSizeSwitch">
                                            </div>
                                        </div>

                                        <button class="btn btn-default" data-toggle="modal" data-target="#frame-color-modal">
                                            <div class="row">
                                                <p class="col-xs-5">Frame Color:</p>
                                                <p class="col-xs-7" data-bind="text: frameColor.name"></p>
                                            </div>
                                        </button>
                                        <button class="btn btn-default" data-toggle="modal" data-target="#brickmould-style-modal">
                                            <div class="row">
                                                <p class="col-xs-5">Brickmould:</p>
                                                <p class="col-xs-7" data-bind="text: brickmouldStyle.name"></p>
                                            </div>
                                        </button>
                                        <button class="btn btn-default" data-toggle="modal" data-target="#jamb-depth-modal">
                                            <div class="row">
                                                <p class="col-xs-5">Wall Depth:</p>
                                                <p class="col-xs-7" data-bind="text: jambDepth.name"></p>
                                            </div>
                                        </button>
                                        <button class="btn btn-default" data-toggle="modal" data-target="#pane-configuration-modal">
                                            <div class="row">
                                                <p class="col-xs-5">Pane Configuration:</p>
                                                <p class="col-xs-7" data-bind="text: paneConfiguration.name"></p>
                                            </div>
                                        </button>
                                    </div>
                                </div>
                            </div>
                            <div class="panel-footer">
                                <button class="btn btn-default" data-dismiss="modal">OK</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @*Grille/SDL Modal*@
        <div class="modal fade" id="grille-sdl-modal" tabindex="-1" role="dialog">
            <div class="modal-dialog" role="document">
                <div class="align-content">
                    <div class="modal-body">
                        <div class="panel panel-default">
                            <div class="panel-heading">
                                Grille/SDL
                                <button type="button" class="close" data-dismiss="modal">
                                    <span>&times;</span>
                                </button>
                            </div>
                            <div class="panel-body">

                                <!-- ko with: selectedSection -->

                                <div class="row grille">
                                    <div class="col-xs-12 control-label">
                                        <p>Grille</p>
                                    </div>
                                    <div class="col-xs-12">
                                        <div class="row">
                                            <div class="col-xs-12 btn-group-vertical" role="group">
                                                <button class="btn btn-default" data-toggle="modal" data-target="#grille-pattern-modal">
                                                    <div class="row">
                                                        <p class="col-xs-5">Pattern:</p>
                                                        <p class="col-xs-7" data-bind="text: grillePattern.name">fake grille</p>
                                                    </div>
                                                </button>
                                                <button class="btn btn-default" data-bind="attr: { disabled: grillePattern.name() === 'None' }" data-toggle="modal" data-target="#grille-color-modal">
                                                    <div class="row">
                                                        <p class="col-xs-5">Color:</p>
                                                        <p class="col-xs-7" data-bind="text: grilleColor.name">fake color</p>
                                                    </div>
                                                </button>
                                                <button class="btn btn-default" data-bind="attr: { disabled: grillePattern.name() === 'None' }" data-toggle="modal" data-target="#grille-size-modal">
                                                    <div class="row">
                                                        <p class="col-xs-5">Size:</p>
                                                        <p class="col-xs-7" data-bind="text: grilleSize.name">1/4 inch</p>
                                                    </div>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-xs-12">
                                        <div class="btn-group" data-toggle="buttons">
                                            <label class="btn btn-default" data-bind="click: $parent.onGrilleAppliesToCurrentClick, css: $parent.grilleAppliesToCurrent ? 'btn btn-default active' : 'btn btn-default'">
                                                <input type="radio" value="thisSection">Selection
                                            </label>
                                            <label class="btn btn-default" data-bind="click: $parent.onGrilleAppliesToOutsideClick, css: $parent.grilleAppliesToOutside ? 'btn btn-default active' : 'btn btn-default'">
                                                <input type="radio" value="outsideSection">Outside
                                            </label>
                                            <label class="btn btn-default" data-bind="click: $parent.onGrilleAppliesToAllClick, css: $parent.grilleAppliesToAll ? 'btn btn-default active' : 'btn btn-default'">
                                                <input type="radio" value="allSections">All
                                            </label>
                                        </div>
                                    </div>
                                </div>

                                <div class="row sdl">
                                    <div class="col-xs-12 control-label">
                                        <p>SDL</p>
                                    </div>
                                    <div class="col-xs-12">
                                        <div class="row">
                                            <div class="col-xs-12 btn-group-vertical" role="group">
                                                <button class="btn btn-default" data-toggle="modal" data-target="#sdl-pattern-modal">
                                                    <div class="row">
                                                        <p class="col-xs-5">Pattern:</p>
                                                        <p class="col-xs-7" data-bind="text: sdlPattern.name">Fake sdl</p>
                                                    </div>
                                                </button>
                                                <button class="btn btn-default" data-bind="attr: { disabled: sdlPattern.name() === 'None' }" data-toggle="modal" data-target="#sdl-color-modal">
                                                    <div class="row">
                                                        <p class="col-xs-5">Color:</p>
                                                        <p class="col-xs-7" data-bind="text: sdlColor.name">Fake color</p>
                                                    </div>
                                                </button>
                                                <button class="btn btn-default" data-bind="attr: { disabled: sdlPattern.name() === 'None' }" data-toggle="modal" data-target="#sdl-size-modal">
                                                    <div class="row">
                                                        <p class="col-xs-5">Size:</p>
                                                        <p class="col-xs-7" data-bind="text: sdlSize.name">1/8 inch</p>
                                                    </div>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-xs-12">
                                        <div class="btn-group" data-toggle="buttons">
                                            <label class="btn btn-default" data-bind="click: $parent.onSdlAppliesToCurrentClick, css: $parent.sdlAppliesToCurrent ? 'btn btn-default active' : 'btn btn-default'">
                                                <input type="radio" value="thisSection">Selection
                                            </label>
                                            <label class="btn btn-default" data-bind="click: $parent.onSdlAppliesToOutsideClick, css: $parent.sdlAppliesToOutside ? 'btn btn-default active' : 'btn btn-default'">
                                                <input type="radio" value="outsideSection">Outside
                                            </label>
                                            <label class="btn btn-default" data-bind="click: $parent.onSdlAppliesToAllClick, css: $parent.sdlAppliesToAll ? 'btn btn-default active' : 'btn btn-default'">
                                                <input type="radio" value="allSections">All
                                            </label>
                                        </div>
                                    </div>
                                </div>

                                <!-- /ko -->

                            </div>
                            <div class="panel-footer">
                                <button class="btn btn-default" data-dismiss="modal">OK</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>


        <div class="modal fade" id="selected-section-modal" tabindex="-1" role="dialog">
            <div class="modal-dialog" role="document">
                <div class="align-content">
                    <div class="modal-body">
                        <div class="panel panel-default">
                            <div class=" panel-heading">
                                Selected Section Settings
                                <button type="button" class="close" data-dismiss="modal">
                                    <span>&times;</span>
                                </button>
                            </div>
                            <div class="panel-body">

                                <!-- ko with: selectedSection -->

                                <div class="row section-width">
                                    <div class="col-xs-12 control-label">
                                        <p>Width</p>
                                    </div>
                                    <div class="col-xs-12">
                                        <input type="text" class="form-control" data-bind="attr: { disabled: $parent.sections().length <= 1 }, value: widthDescription">
                                    </div>
                                    <div class="col-xs-12">
                                        <div class="row">
                                            <div class="col-xs-12">
                                                <div class="btn-group" data-toggle="buttons">
                                                    <label class="btn btn-default" data-bind="click: $parent.onSectionWidthAppliesToCurrentClick, css: $parent.sectionWidthAppliesToCurrent ? 'btn btn-default active' : 'btn btn-default'">
                                                        <input type="radio" value="thisSection">Selection
                                                    </label>
                                                    <label class="btn btn-default" data-bind="click: $parent.onSectionWidthAppliesToOutsideClick, css: $parent.sectionWidthAppliesToOutside ? 'btn btn-default active' : 'btn btn-default'">
                                                        <input type="radio" value="outsideSection">Outside
                                                    </label>
                                                    <label class="btn btn-default" data-bind="click: $parent.onSectionWidthAppliesToAllClick, css: $parent.sectionWidthAppliesToAll ? 'btn btn-default active' : 'btn btn-default'">
                                                        <input type="radio" value="allSections">All
                                                    </label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row operation">
                                    <div class="col-xs-12 control-label">
                                        <p>Operation</p>
                                    </div>
                                    <div class="col-xs-12">
                                        <div class="row">
                                            <div class="col-xs-12 btn-group-vertical" role="group">
                                                <button class="btn btn-default" data-toggle="modal" data-target="#operational-style-modal">
                                                    <div class="row">
                                                        <p class="col-xs-5">Style:</p>
                                                        <p class="col-xs-7" data-bind="text: style.name">Temporary name</p>
                                                    </div>
                                                </button>
                                                <button class="col-xs-6 btn btn-default" data-bind="attr: { disabled: !style.hasCrank() }" data-toggle="modal" data-target="#crank-modal">
                                                    <div class="row">
                                                        <p class="col-xs-5">Crank:</p>
                                                        <p class="col-xs-7" data-bind="text: crank.name">Fake crank</p>
                                                    </div>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-xs-12">
                                        <div class="row">
                                            <div class="col-xs-12">
                                                <div class="btn-group" data-toggle="buttons">
                                                    <label class="btn btn-default" data-bind="click: $parent.onStyleAppliesToCurrentClick, css: $parent.styleAppliesToCurrent ? 'btn btn-default active' : 'btn btn-default'">
                                                        <input type="radio" value="thisSection">Selection
                                                    </label>
                                                    <label class="btn btn-default" data-bind="click: $parent.onStyleAppliesToOutsideClick, css: $parent.styleAppliesToOutside ? 'btn btn-default active' : 'btn btn-default'">
                                                        <input type="radio" value="outsideSection">Outside
                                                    </label>
                                                    <label class="btn btn-default" data-bind="click: $parent.onStyleAppliesToAllClick, css: $parent.styleAppliesToAll ? 'btn btn-default active' : 'btn btn-default'">
                                                        <input type="radio" value="allSections">All
                                                    </label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- /ko -->

                            </div>
                            <div class="panel-footer">
                                <button class="btn btn-default" data-dismiss="modal">OK</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Product Line Modal -->

        <div class="modal fade" id="product-modal" tabindex="-1" role="dialog">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <button type="button" class="close" data-dismiss="modal">
                            <span>&times;</span>
                        </button>
                        <h4 class="modal-title" id="myModalLabel">Choose a Product Line</h4>
                    </div>
                    <div class="modal-body">
                        <div class="list-group">

                            <!-- ko foreach: productLines -->

                            <a class="list-group-item" data-dismiss="modal" href="#" data-bind="text: name, click: $parent.onProductLineSelected"></a>

                            <!-- /ko -->

                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Frame Color Modal -->

        <div class="modal fade" id="frame-color-modal" tabindex="-1" role="dialog">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <button type="button" class="close" data-dismiss="modal">
                            <span>&times;</span>
                        </button>
                        <h4 class="modal-title" id="myModalLabel">Choose a Color</h4>
                    </div>
                    <div class="modal-body">
                        <div class="list-group">

                            <!-- ko foreach: productLine.frameColors -->

                            <a class="list-group-item" data-dismiss="modal" href="#" data-bind="text: name, click: $parent.onFrameColorSelected"></a>

                            <!-- /ko -->

                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Wall Depth Modal -->

        <div class="modal fade" id="jamb-depth-modal" tabindex="-1" role="dialog">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <button type="button" class="close" data-dismiss="modal">
                            <span>&times;</span>
                        </button>
                        <h4 class="modal-title" id="myModalLabel">Choose a Wall Depth</h4>
                    </div>
                    <div class="modal-body">
                        <div class="list-group">

                            <!-- ko foreach: productLine.jambDepths -->

                            <a class="list-group-item" data-dismiss="modal" href="#" data-bind="text: name, click: $parent.onJambDepthSelected"></a>

                            <!-- /ko -->

                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Pane Configurations Modal -->

        <div class="modal fade" id="pane-configuration-modal" tabindex="-1" role="dialog">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <button type="button" class="close" data-dismiss="modal">
                            <span>&times;</span>
                        </button>
                        <h4 class="modal-title" id="myModalLabel">Choose Your Pane Configuration</h4>
                    </div>
                    <div class="modal-body">
                        <div class="list-group">

                            <!-- ko foreach: productLine.paneConfigurations -->

                            <a class="list-group-item" href="#" data-dismiss="modal" data-bind="text: name, click: $parent.onPaneConfugurationSelected"></a>

                            <!-- /ko -->

                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Brickmould Style Modal -->

        <div class="modal fade" id="brickmould-style-modal" tabindex="-1" role="dialog">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <button type="button" class="close" data-dismiss="modal">
                            <span>&times;</span>
                        </button>
                        <h4 class="modal-title" id="myModalLabel">Choose a Brickmould Style</h4>
                    </div>
                    <div class="modal-body">
                        <div class="list-group">

                            <!-- ko foreach: productLine.brickmouldStyles -->

                            <a class="list-group-item" data-dismiss="modal" href="#" data-bind="text: name, click: $parent.onBrickmouldStyleSelected"></a>

                            <!-- /ko -->

                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Brickmould Color Modal -->

        <div class="modal fade" id="brickmould-color-modal" tabindex="-1" role="dialog">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <button type="button" class="close" data-dismiss="modal">
                            <span>&times;</span>
                        </button>
                        <h4 class="modal-title" id="myModalLabel">Choose a Brickmould Color</h4>
                    </div>
                    <div class="modal-body">
                        <div class="list-group">

                            <!-- ko foreach: productLine.brickmouldColors -->

                            <a class="list-group-item" data-dismiss="modal" href="#" data-bind="text: name, click: $parent.onBrickmouldColorSelected"></a>

                            <!-- /ko -->

                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Operational Style Modal -->

        <div class="modal fade" id="operational-style-modal" tabindex="-1" role="dialog">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <button type="button" class="close" data-dismiss="modal">
                            <span>&times;</span>
                        </button>
                        <h4 class="modal-title" id="myModalLabel">Choose an Operational Style</h4>
                    </div>
                    <div class="modal-body">
                        <div class="list-group">

                            <!-- ko foreach: productLine.operationalStyles -->

                            <a class="list-group-item" data-dismiss="modal" href="#" data-bind="text: name, click: $parent.onStyleSelected"></a>

                            <!-- /ko -->

                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Crank Modal -->

        <div class="modal fade" id="crank-modal" tabindex="-1" role="dialog">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <button type="button" class="close" data-dismiss="modal">
                            <span>&times;</span>
                        </button>
                        <h4 class="modal-title" id="myModalLabel">Choose a Crank</h4>
                    </div>
                    <div class="modal-body">
                        <div class="list-group">

                            <!-- ko foreach: productLine.cranks -->

                            <a class="list-group-item" data-dismiss="modal" href="#" data-bind="text: name, click: $parent.onCrankSelected"></a>

                            <!-- /ko -->

                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Grille Pattern Modal -->

        <div class="modal fade" id="grille-pattern-modal" tabindex="-1" role="dialog">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <button type="button" class="close" data-dismiss="modal">
                            <span>&times;</span>
                        </button>
                        <h4 class="modal-title" id="myModalLabel">Choose a Grille Pattern</h4>
                    </div>
                    <div class="modal-body">
                        <div class="list-group">

                            <!-- ko foreach: productLine.grillePatterns -->

                            <a class="list-group-item" data-dismiss="modal" href="#" data-bind="text: name, click: $parent.onGrillePatternSelected"></a>

                            <!-- /ko -->

                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Grille Color Modal -->

