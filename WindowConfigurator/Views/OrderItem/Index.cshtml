    <script src="~/js/jquery-3.1.0.js"></script>
    <script src="~/js/bootstrap.js"></script>

    <script>
        //$(window).on('load', function () {
        //  $('#under-construction-modal').modal('show');
        //});
        $('#closemodal').click(function () {
          $('#under-construction-modal').modal('hide');
        });
        $('#quote-modal').on('shown.bs.modal', function () {
          ga('send', 'event', 'site', 'quote-modal');
        });

        var itemViewModel = new windowStore.order.item.ItemViewModel();
        itemViewModel.loadItem("energySaverItemTemplate", "@Model.Id", function () {
          ko.applyBindings(itemViewModel, $("body")[0]);
        });

        $("#window-submit-btn").click(function () {
          itemViewModel.complete();
        });

        $(window).on('resize', function () {
          itemViewModel.updatePreview();
        });
        $("#quote-submit-btn").click(function () {
          //var content = "Callback number: " + $("#text-callback-number").val();
          //content += "\n"
          //content += "Message: " + $("#text-content").val();

          var content = "Callback number: " + $("#quote-text-callback-number").val();
          content += itemViewModel.getSpec();

          $.ajax({
            url: "/text",
            type: "POST",
            data: { content: content }
          })
          .done(function () { })
          .fail(function () { alert("text failed"); });

          $('#quote-modal').modal('toggle');

          // Google event tracking
          ga('send', 'event', 'phone', 'quote-submit');
        });

    </script>

