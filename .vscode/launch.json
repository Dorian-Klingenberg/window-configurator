{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "C# + JS (Edge)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/WindowConfigurator/bin/Debug/net10.0/WindowConfigurator.Web.dll",
      "args": [],
      "cwd": "${workspaceFolder}/WindowConfigurator",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5149"
      },
      "serverReadyAction": {
        "action": "debugWithEdge",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
        "uriFormat": "%s/00000000-0000-0000-0000-000000000001",
        "webRoot": "${workspaceFolder}/WindowConfigurator/wwwroot"
      }
    },
    {
      "name": "C# + JS (Chrome)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/WindowConfigurator/bin/Debug/net10.0/WindowConfigurator.Web.dll",
      "args": [],
      "cwd": "${workspaceFolder}/WindowConfigurator",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5149"
      },
      "serverReadyAction": {
        "action": "debugWithChrome",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
        "uriFormat": "%s/00000000-0000-0000-0000-000000000001",
        "webRoot": "${workspaceFolder}/WindowConfigurator/wwwroot"
      }
    }
  ]
}
