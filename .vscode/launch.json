{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "_Internal: Configurator (Edge)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-configurator",
      "program": "${workspaceFolder}/WindowConfigurator/bin/Debug/net10.0/WindowConfigurator.Web.dll",
      "args": [],
      "cwd": "${workspaceFolder}/WindowConfigurator",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5149"
      },
      "serverReadyAction": {
        "action": "debugWithEdge",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
        "uriFormat": "%s/00000000-0000-0000-0000-000000000001",
        "webRoot": "${workspaceFolder}/WindowConfigurator/wwwroot"
      },
      "presentation": {
        "hidden": true
      }
    },
    {
      "name": "WindowConfigurator: API (5149)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-slice-b-demo",
      "program": "${workspaceFolder}/WindowConfigurator/bin/Debug/net10.0/WindowConfigurator.Web.dll",
      "args": [],
      "cwd": "${workspaceFolder}/WindowConfigurator",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5149"
      }
    },
    {
      "name": "WindowConfigurator: Mock CRM (5152)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "watch-and-open-crm-chrome",
      "program": "${workspaceFolder}/MockContractorCrm/bin/Debug/net10.0/MockContractorCrm.dll",
      "args": [],
      "cwd": "${workspaceFolder}/MockContractorCrm",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5152"
      }
    },
    {
      "name": "_Internal: Mock Contractor Site Server",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-mock-contractor-site",
      "program": "${workspaceFolder}/MockContractorSite/bin/Debug/net10.0/MockContractorSite.dll",
      "args": [],
      "cwd": "${workspaceFolder}/MockContractorSite",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5151"
      },
      "presentation": {
        "hidden": true
      }
    },
    {
      "name": "_Internal: Open Mock Contractor Site (Chrome)",
      "type": "pwa-chrome",
      "request": "launch",
      "preLaunchTask": "wait-port-5151",
      "url": "http://localhost:5151/",
      "presentation": {
        "hidden": true
      }
    }
  ],
  "compounds": [
    {
      "name": "WindowConfigurator: Debug Slice B (CRM + Configurator)",
      "configurations": [
        "WindowConfigurator: API (5149)",
        "WindowConfigurator: Mock CRM (5152)"
      ],
      "stopAll": true
    },
    {
      "name": "Run Slice A Demo (Both Sites in Chrome)",
      "configurations": [
        "WindowConfigurator: API (5149)",
        "_Internal: Mock Contractor Site Server",
        "_Internal: Open Mock Contractor Site (Chrome)"
      ],
      "stopAll": true
    }
  ]
}
